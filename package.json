{
  "name": "dani-codium",
  "displayName": "dani-codium",
  "description": "My config",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "vscodevim.vim",
    "jdinhlife.gruvbox",
    "TomPollak.lazygit-vscode"
  ],
  "extensionPack": [
    "yzhang.markdown-all-in-one",
    "ms-python.python",
    "ms-python.black-formatter",
    "christian-kohler.path-intellisense",
    "mechatroner.rainbow-csv",
    "formulahendry.code-runner",
    "tamasfe.even-better-toml"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dani-codium.applyRecommendedSettings",
        "title": "Dani: Apply settings"
      },
      {
        "command": "dani-codium.applyRecommendedKeybindings",
        "title": "Dani: Apply keybindings"
      },
      {
        "command": "dani-codium.showQuickActions",
        "title": "Dani: Show quick actions"
      }
    ],
    "configuration": {
      "title": "Dani Codium",
      "properties": {
        "dani-codium.quickActions": {
          "type": "array",
          "default": [],
          "description": "Configurable quick actions. Each item should have a 'key', 'description', and either a 'command' or an 'actions' array for a submenu.",
          "items": {
            "type": "object",
            "required": [
              "key",
              "description"
            ],
            "properties": {
              "key": {
                "type": "string",
                "description": "The key (letter) to trigger the action"
              },
              "command": {
                "type": "string",
                "description": "The command ID to execute"
              },
              "description": {
                "type": "string",
                "description": "A brief description of the action"
              },
              "actions": {
                "type": "array",
                "description": "A list of sub-actions. If this is provided, 'command' is ignored.",
                "items": {
                  "$ref": "#/properties/dani-codium.quickActions/items"
                }
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "jsonc-parser": "^3.3.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  }
}